{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "14628194261960081317"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "osType": {
      "type": "string",
      "defaultValue": "Ubuntu",
      "allowedValues": [
        "Ubuntu",
        "Windows"
      ],
      "metadata": {
        "description": "Operating system type"
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_B2s",
      "metadata": {
        "description": "VM size SKU"
      }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureclaw",
      "metadata": {
        "description": "Admin username"
      }
    },
    "adminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Admin password (password authentication)"
      }
    },
    "enablePublicHttps": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable public HTTPS access via Caddy + Let's Encrypt (uses Azure VM DNS name)"
      }
    },
    "gatewayPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Gateway password for authentication (required when enablePublicHttps is true)"
      }
    }
  },
  "variables": {
    "repoBaseUrl": "https://raw.githubusercontent.com/shuaihuadu/azure-claw/main/scripts",
    "ubuntuScriptUrl": "[format('{0}/install-openclaw-ubuntu.sh', variables('repoBaseUrl'))]",
    "windowsScriptUrl": "[format('{0}/install-openclaw-windows.ps1', variables('repoBaseUrl'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "network",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "osType": {
            "value": "[parameters('osType')]"
          },
          "enablePublicHttps": {
            "value": "[parameters('enablePublicHttps')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "10412141972104163192"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for all resources"
              }
            },
            "osType": {
              "type": "string",
              "allowedValues": [
                "Ubuntu",
                "Windows"
              ],
              "metadata": {
                "description": "Operating system type, controls NSG inbound rules"
              }
            },
            "enablePublicHttps": {
              "type": "bool",
              "defaultValue": false,
              "metadata": {
                "description": "Enable public HTTPS access via Caddy reverse proxy"
              }
            }
          },
          "variables": {
            "sshRule": {
              "name": "Allow-SSH",
              "properties": {
                "priority": 1000,
                "direction": "Inbound",
                "access": "Allow",
                "protocol": "Tcp",
                "sourcePortRange": "*",
                "destinationPortRange": "22",
                "sourceAddressPrefix": "*",
                "destinationAddressPrefix": "*"
              }
            },
            "rdpRule": {
              "name": "Allow-RDP",
              "properties": {
                "priority": 1000,
                "direction": "Inbound",
                "access": "Allow",
                "protocol": "Tcp",
                "sourcePortRange": "*",
                "destinationPortRange": "3389",
                "sourceAddressPrefix": "*",
                "destinationAddressPrefix": "*"
              }
            },
            "gatewayRule": {
              "name": "Allow-Gateway",
              "properties": {
                "priority": 1100,
                "direction": "Inbound",
                "access": "Allow",
                "protocol": "Tcp",
                "sourcePortRange": "*",
                "destinationPortRange": "18789",
                "sourceAddressPrefix": "*",
                "destinationAddressPrefix": "*"
              }
            },
            "httpsRule": {
              "name": "Allow-HTTPS",
              "properties": {
                "priority": 1200,
                "direction": "Inbound",
                "access": "Allow",
                "protocol": "Tcp",
                "sourcePortRange": "*",
                "destinationPortRange": "443",
                "sourceAddressPrefix": "*",
                "destinationAddressPrefix": "*"
              }
            },
            "httpChallengeRule": {
              "name": "Allow-HTTP-Challenge",
              "properties": {
                "priority": 1300,
                "direction": "Inbound",
                "access": "Allow",
                "protocol": "Tcp",
                "sourcePortRange": "*",
                "destinationPortRange": "80",
                "sourceAddressPrefix": "*",
                "destinationAddressPrefix": "*"
              }
            },
            "nsgRules": "[if(equals(parameters('osType'), 'Ubuntu'), if(parameters('enablePublicHttps'), createArray(variables('sshRule'), variables('httpsRule'), variables('httpChallengeRule')), createArray(variables('sshRule'), variables('gatewayRule'))), if(parameters('enablePublicHttps'), createArray(variables('rdpRule'), variables('httpsRule'), variables('httpChallengeRule')), createArray(variables('rdpRule'), variables('gatewayRule'))))]",
            "dnsLabel": "[format('openclaw-{0}', uniqueString(resourceGroup().id))]"
          },
          "resources": [
            {
              "type": "Microsoft.Network/networkSecurityGroups",
              "apiVersion": "2024-05-01",
              "name": "openclaw-nsg",
              "location": "[parameters('location')]",
              "properties": {
                "securityRules": "[variables('nsgRules')]"
              }
            },
            {
              "type": "Microsoft.Network/virtualNetworks",
              "apiVersion": "2024-05-01",
              "name": "openclaw-vnet",
              "location": "[parameters('location')]",
              "properties": {
                "addressSpace": {
                  "addressPrefixes": [
                    "10.0.0.0/16"
                  ]
                },
                "subnets": [
                  {
                    "name": "openclaw-subnet",
                    "properties": {
                      "addressPrefix": "10.0.0.0/24",
                      "networkSecurityGroup": {
                        "id": "[resourceId('Microsoft.Network/networkSecurityGroups', 'openclaw-nsg')]"
                      }
                    }
                  }
                ]
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/networkSecurityGroups', 'openclaw-nsg')]"
              ]
            },
            {
              "type": "Microsoft.Network/publicIPAddresses",
              "apiVersion": "2024-05-01",
              "name": "openclaw-ip",
              "location": "[parameters('location')]",
              "sku": {
                "name": "Standard"
              },
              "properties": {
                "publicIPAllocationMethod": "Static",
                "dnsSettings": {
                  "domainNameLabel": "[variables('dnsLabel')]"
                }
              }
            }
          ],
          "outputs": {
            "subnetId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Network/virtualNetworks', 'openclaw-vnet'), '2024-05-01').subnets[0].id]"
            },
            "publicIpId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Network/publicIPAddresses', 'openclaw-ip')]"
            },
            "publicIpAddress": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', 'openclaw-ip'), '2024-05-01').ipAddress]"
            },
            "fqdn": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', 'openclaw-ip'), '2024-05-01').dnsSettings.fqdn]"
            }
          }
        }
      }
    },
    {
      "condition": "[equals(parameters('osType'), 'Ubuntu')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "vm-ubuntu",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
