          },
          "subnetId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'network'), '2025-04-01').outputs.subnetId.value]"
          },
          "publicIpId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'network'), '2025-04-01').outputs.publicIpId.value]"
          },
          "scriptUrl": {
            "value": "[variables('ubuntuScriptUrl')]"
          },
          "enablePublicHttps": {
            "value": "[parameters('enablePublicHttps')]"
          },
          "gatewayPassword": {
            "value": "[parameters('gatewayPassword')]"
          },
          "fqdn": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'network'), '2025-04-01').outputs.fqdn.value]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "14220820567670021826"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region"
              }
            },
            "vmSize": {
              "type": "string",
              "metadata": {
